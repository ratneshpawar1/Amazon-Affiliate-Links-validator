{
  "name": "yt-amazon-affiliate-link-auditor",
  "version": "0.1.0",
  "description": "Chrome MV3 extension that audits Amazon affiliate links across a YouTube channel and reports which are dead, hijacked, or losing commission.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.278",
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
